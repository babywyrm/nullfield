FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /nullfield-controller ./cmd/nullfield-controller

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /nullfield-controller /nullfield-controller
USER nonroot:nonroot
EXPOSE 9091 9092 9093
ENTRYPOINT ["/nullfield-controller"]
