FROM golang:1.25 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /nullfield-injector ./cmd/nullfield-injector

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /nullfield-injector /nullfield-injector
USER 65534:65534
ENTRYPOINT ["/nullfield-injector"]
